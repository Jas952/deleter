# Twitter User ID (numeric, see skill.md for how to get)
TWITTER_USER_ID=123456789

# Cookies из браузера (JSON объект)
TWITTER_COOKIES='{"auth_token":"xxx","ct0":"yyy","guest_id":"zzz","kdt":"...","twid":"...","...":"..."}'

# HTTP Headers из браузера (JSON объект)
TWITTER_HEADERS='{"authorization":"Bearer AAAAAAAAAAAAAAAAAAAAANRILgAAAAAAnNwIzUejR...","x-csrf-token":"yyy","x-twitter-active-user":"yes","x-twitter-auth-type":"OAuth2Session","x-twitter-client-language":"en","user-agent":"Mozilla/5.0..."}'

# GraphQL Query IDs - перехватите из DevTools при загрузке профиля
QUERY_ID_USER_TWEETS=xxxxxxx
QUERY_ID_DELETE_RETWEET=yyyyyyy

# Ключевые слова для поиска (через запятую, регистр не важен)
KEYWORDS=GIVEAWAY,RUNE

# Задержка между удалениями (секунды, рекомендуется 10+ для избежания rate limit)
DELETE_DELAY_SEC=10

# Макс. страниц для обработки (0 = без лимита)
MAX_PAGES=0
